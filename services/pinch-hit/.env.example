# Required
export TWITTERAPI_IO_KEY=
export PINCH_HIT_WEBHOOK_URL=

# Optional — ops notifications (degradation/recovery alerts)
export OPS_WEBHOOK_URL=

# Optional — shared secret for twitterapi.io POST /webhook?secret=...
export TWITTER_WEBHOOK_SECRET=

# Optional — odds enrichment (skipped if unset)
export ODDS_API_KEY=

# Optional — defaults shown
export DB_PATH=/data/pinch-hit.db
export GAME_HOURS_START=12
export GAME_HOURS_END=6
export LATE_INNING_THRESHOLD=6
export TIMEOUT_MINUTES=5
export PORT=8080
